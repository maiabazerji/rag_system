# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=

# Generator selection: local | anthropic | openai
GENERATOR_PROVIDER=local

# Ollama host:
#   - Inside Docker (default), the backend reaches the host machine's Ollama via
#     host.docker.internal — already wired in infra/docker-compose.yml, so leave blank.
#   - Outside Docker (running uvicorn directly), use http://localhost:11434.
OLLAMA_HOST=
OLLAMA_MODEL=llama3.1:8b
OPENAI_GENERATOR_MODEL=gpt-4o-mini

# Langfuse (self-hosted, see docker-compose)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Weights & Biases (optional — eval-run dashboards)
# Leave WANDB_API_KEY blank to disable. Use WANDB_MODE=offline for local-only runs.
WANDB_API_KEY=
WANDB_PROJECT=evalrag
WANDB_MODE=online
